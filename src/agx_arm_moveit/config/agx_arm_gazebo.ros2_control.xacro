<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="agx_arm_gazebo_ros2_control" params="name arm_type effector_type revo2_type">

    <!-- ── Helper macro: one Gazebo-sim joint ── -->
    <xacro:macro name="gz_joint" params="joint_name lower_limit:=0 upper_limit:=0">
      <joint name="${joint_name}">
        <command_interface name="position">
          <param name="min">${lower_limit}</param>
          <param name="max">${upper_limit}</param>
        </command_interface>
        <command_interface name="velocity" />
        <command_interface name="effort" />
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="effort">
          <param name="initial_value">0.0</param>
        </state_interface>
      </joint>
    </xacro:macro>

    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <!-- ── Arm joints (shared across all arm types) ── -->
      <xacro:gz_joint joint_name="joint1" lower_limit="-2.70526" upper_limit="2.70526" />
      <xacro:gz_joint joint_name="joint2" lower_limit="-1.74"    upper_limit="1.74" />
      <xacro:gz_joint joint_name="joint3" lower_limit="-2.75"    upper_limit="2.75" />
      <xacro:gz_joint joint_name="joint4" lower_limit="-1.01"    upper_limit="2.14" />
      <xacro:gz_joint joint_name="joint5" lower_limit="-2.75"    upper_limit="2.75" />
      <xacro:gz_joint joint_name="joint6" lower_limit="-0.73"    upper_limit="0.95" />

      <!-- NERO 7th joint -->
      <xacro:if value="${arm_type == 'nero'}">
        <xacro:gz_joint joint_name="joint7" lower_limit="-1.5707963" upper_limit="1.5707963" />
      </xacro:if>

      <!-- ── Gripper joints ── -->
      <xacro:if value="${effector_type == 'agx_gripper'}">
        <xacro:gz_joint joint_name="gripper_joint1" lower_limit="0"     upper_limit="0.05" />
        <xacro:gz_joint joint_name="gripper_joint2" lower_limit="-0.05" upper_limit="0" />
      </xacro:if>

      <!-- ── Revo2 hand joints ── -->
      <xacro:if value="${effector_type == 'revo2' and revo2_type == 'left'}">
        <xacro:gz_joint joint_name="left_thumb_metacarpal_joint" lower_limit="0" upper_limit="1.57" />
        <xacro:gz_joint joint_name="left_thumb_proximal_joint"   lower_limit="0" upper_limit="1.03" />
        <xacro:gz_joint joint_name="left_index_proximal_joint"   lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="left_middle_proximal_joint"  lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="left_ring_proximal_joint"    lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="left_pinky_proximal_joint"   lower_limit="0" upper_limit="1.41" />
      </xacro:if>
      <xacro:if value="${effector_type == 'revo2' and revo2_type == 'right'}">
        <xacro:gz_joint joint_name="right_thumb_metacarpal_joint" lower_limit="0" upper_limit="1.57" />
        <xacro:gz_joint joint_name="right_thumb_proximal_joint"   lower_limit="0" upper_limit="1.03" />
        <xacro:gz_joint joint_name="right_index_proximal_joint"   lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="right_middle_proximal_joint"  lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="right_ring_proximal_joint"    lower_limit="0" upper_limit="1.41" />
        <xacro:gz_joint joint_name="right_pinky_proximal_joint"   lower_limit="0" upper_limit="1.41" />
      </xacro:if>
    </ros2_control>
  </xacro:macro>
</robot>
