#!/usr/bin/env python3
"""
SmartHeight node – computes IK for a height-based end-effector target
and writes the resulting joint configuration to a CSV file.

Uses ikpy for IK solving (no MoveIt dependency).

Service: smart_height (SmartHeight)
  Input : height (float64)
  Output: success (bool), message (string)

Target end-effector position (in base_link frame):
  x = 0.25
  y = -0.36
  z = height - 1.0  (default 0.2135 when height < 1.0 m)

After IK solve, writes a 36-point interpolated trajectory (zeros → solution)
to waypoints_to_point.csv, waits 1.2 s, then calls /play_trajectory.
"""
import csv
import time
import numpy as np

import rclpy
from rclpy.node import Node
from rclpy.callback_groups import ReentrantCallbackGroup
from rclpy.executors import MultiThreadedExecutor
from sensor_msgs.msg import JointState
from scipy.spatial.transform import Rotation as R

import ikpy.chain

from agx_custom_trajectory.srv import SmartHeight, PlayTrajectory

JOINT_NAMES = [
    'joint1', 'joint2', 'joint3', 'joint4',
    'joint5', 'joint6', 'joint7',
]
OUTPUT_CSV = '/home/jess/Documents/repos/agx_arm_ws/data/waypoints_to_point.csv'
PROFILE_CSV = '/home/jess/Documents/repos/agx_arm_ws/data/waypoints_to_point_def.csv'

# ── Target position constraints ──
TARGET_X = 0.25
TARGET_Y = -0.36
DEFAULT_Z = 0.2135  # fallback when height < 1.0 m

# ── Target orientation (quaternion xyzw) ──
TARGET_QX = 0.3839
TARGET_QY = -0.4847
TARGET_QZ = 0.5232
TARGET_QW = 0.5865

# Pre-compute rotation matrix from quaternion
TARGET_ROTATION = R.from_quat([TARGET_QX, TARGET_QY, TARGET_QZ, TARGET_QW]).as_matrix()

# URDF path (resolved at module level for the nero arm)
URDF_PATH = '/home/jess/Documents/repos/agx_arm_ws/src/agx_description/agx_arm_urdf/nero/urdf/nero_description.urdf'


class SmartHeightNode(Node):
    def __init__(self):
        super().__init__('smart_height')
        cb_group = ReentrantCallbackGroup()

        # ── Load kinematic chain from URDF ──
        # ikpy adds a fixed origin link at index 0; active joints are indices 1..7
        self._chain = ikpy.chain.Chain.from_urdf_file(
            URDF_PATH,
            base_elements=['base_link'],
            active_links_mask=[False, True, True, True, True, True, True, True],
        )

        # ── Load interpolation profile (normalized 0→1) from reference CSV ──
        self._profile = self._load_profile(PROFILE_CSV)

        # ── Service ──
        self.create_service(
            SmartHeight, 'smart_height', self._handle_cb,
            callback_group=cb_group,
        )

        # ── PlayTrajectory client ──
        self._play_client = self.create_client(
            PlayTrajectory, '/play_trajectory',
            callback_group=cb_group,
        )

        # ── Joint-state cache (used as IK seed) ──
        self._joint_state = None
        self.create_subscription(
            JointState, '/joint_states', self._js_cb, 10,
        )

        self.get_logger().info('SmartHeight node ready (ikpy)')

    # ── Helpers ─────────────────────────────────────────────────

    @staticmethod
    def _load_profile(path):
        """Load normalized interpolation profile (0→1) from a reference CSV."""
        with open(path) as f:
            reader = csv.reader(f)
            next(reader)  # skip header
            rows = [list(map(float, r)) for r in reader]
        final = rows[-1][0]
        return [row[0] / final for row in rows]

    # ── Callbacks ──────────────────────────────────────────────

    def _js_cb(self, msg: JointState):
        self._joint_state = msg

    def _handle_cb(self, request, response):
        height = request.height
        z = (height - 1.0) if height >= 1.0 else DEFAULT_Z
        self.get_logger().info(
            f'smart_height called  height={height:.4f}  target z={z:.4f}'
        )

        target_position = [TARGET_X, TARGET_Y, z]

        # ── Build seed from current joint state ──
        # ikpy expects array of length len(chain.links) — index 0 is the fixed base
        seed = [0.0] * len(self._chain.links)
        if self._joint_state is not None:
            pos_map = dict(zip(self._joint_state.name, self._joint_state.position))
            for i, name in enumerate(JOINT_NAMES):
                seed[i + 1] = pos_map.get(name, 0.0)

        # ── Solve IK ──
        try:
            ik_solution = self._chain.inverse_kinematics(
                target_position=target_position,
                target_orientation=TARGET_ROTATION,
                orientation_mode='all',
                initial_position=seed,
            )
        except Exception as e:
            response.success = False
            response.message = f'IK solver error: {e}'
            self.get_logger().error(response.message)
            return response

        # Extract active joint values (skip index 0 = fixed base link)
        joint_values = ik_solution[1:1 + len(JOINT_NAMES)].tolist()

        # ── Interpolate from zeros → IK solution using trapezoidal profile ──
        with open(OUTPUT_CSV, 'w', newline='') as f:
            writer = csv.writer(f)
            writer.writerow(JOINT_NAMES)
            for p in self._profile:
                row = [p * v for v in joint_values]
                writer.writerow([f'{v:.6f}' if v != 0.0 else '0.000000' for v in row])

        self.get_logger().info(
            f'Trajectory ({len(self._profile)} pts) saved to {OUTPUT_CSV}  '
            f'target=({TARGET_X}, {TARGET_Y}, {z:.4f})'
        )

        # ── Wait, then play the trajectory ──
        time.sleep(1.2)

        if not self._play_client.wait_for_service(timeout_sec=5.0):
            response.success = False
            response.message = '/play_trajectory service not available'
            self.get_logger().error(response.message)
            return response

        play_req = PlayTrajectory.Request()
        play_req.file_path = OUTPUT_CSV
        play_req.reverse = False
        play_result = self._play_client.call(play_req)

        response.success = play_result.success
        response.message = play_result.message
        self.get_logger().info(f'play_trajectory: {play_result.message}')
        return response


def main():
    rclpy.init()
    node = SmartHeightNode()
    executor = MultiThreadedExecutor()
    executor.add_node(node)
    try:
        executor.spin()
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.try_shutdown()


if __name__ == '__main__':
    main()
